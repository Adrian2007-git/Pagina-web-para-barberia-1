<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Barbería Elegance</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#f5f5f5;
    color:#333;
}

header{
    background:#111;
    color:white;
    padding:20px;
    text-align:center;
}

header h1{
    font-size:40px;
}

nav{
    margin-top:15px;
}

nav a{
    color:white;
    text-decoration:none;
    margin:15px;
    font-weight:bold;
}

.hero{
    background:linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.6)),
    url("https://images.unsplash.com/photo-1622286342621-4bd786c2447c?auto=format&fit=crop&w=1200&q=80");
    background-size:cover;
    background-position:center;
    color:white;
    text-align:center;
    padding:120px 20px;
}

.hero h2{
    font-size:50px;
}

.hero p{
    margin-top:20px;
    font-size:20px;
}

.boton{
    display:inline-block;
    margin-top:30px;
    background:#c59d5f;
    color:white;
    padding:15px 30px;
    text-decoration:none;
    border-radius:5px;
}

section{
    padding:60px 20px;
}

h2{
    text-align:center;
    margin-bottom:30px;
}

.servicios{
    display:flex;
    justify-content:center;
    flex-wrap:wrap;
    gap:20px;
}

.tarjeta{
    background:white;
    width:250px;
    padding:20px;
    border-radius:10px;
    box-shadow:0 5px 15px rgba(0,0,0,.2);
    text-align:center;
}

.tarjeta h3{
    margin-bottom:10px;
}

.galeria{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:15px;
}

.galeria img{
    width:100%;
    border-radius:10px;
    height:220px;
    object-fit:cover;
}

form{
    max-width:500px;
    margin:auto;
    background:white;
    padding:30px;
    border-radius:10px;
    box-shadow:0 0 10px rgba(0,0,0,.2);
}

input, select{
    width:100%;
    padding:12px;
    margin:10px 0;
}

button{
    width:100%;
    padding:15px;
    background:#111;
    color:white;
    border:none;
    cursor:pointer;
    font-size:17px;
}

button:hover{
    background:#c59d5f;
}

footer{
    background:#111;
    color:white;
    text-align:center;
    padding:20px;
}
</style>

</head>
<body>

<header>

<h1>Barbería Elegance</h1>

<nav>
<a href="#inicio">Inicio</a>
<a href="#servicios">Servicios</a>
<a href="#galeria">Galería</a>
<a href="#reserva">Reserva</a>
<a href="#contacto">Contacto</a>
</nav>

</header>

<section class="hero" id="inicio">

<h2>Tu estilo comienza aquí</h2>

<p>Cortes modernos, clásicos y arreglo de barba con profesionales.</p>

<a href="#reserva" class="boton">Reservar Cita</a>

</section>

<section id="servicios">

<h2>Nuestros Servicios</h2>

<div class="servicios">

<div class="tarjeta">
<h3>Corte Clásico</h3>
<p>$8.00</p>
</div>

<div class="tarjeta">
<h3>Corte Premium</h3>
<p>$12.00</p>
</div>

<div class="tarjeta">
<h3>Barba</h3>
<p>$5.00</p>
</div>

<div class="tarjeta">
<h3>Corte + Barba</h3>
<p>$15.00</p>
</div>

</div>

</section>

<section id="galeria">

<h2>Galería</h2>

<div class="galeria">

<img src="https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=600&q=80">

<img src="https://images.unsplash.com/photo-1621605815971-fbc98d665033?auto=format&fit=crop&w=600&q=80">

<img src="https://images.unsplash.com/photo-1503951914875-452162b0f3f1?auto=format&fit=crop&w=600&q=80">

</div>

</section>

<section id="reserva">

<h2>Reserva tu Cita</h2>

<form id="formulario">

<input type="text" placeholder="Nombre completo" required>

<input type="tel" placeholder="Teléfono" required>

<input type="date" required>

<input type="time" required>

<select required>

<option value="">Seleccione un servicio</option>

<option>Corte Clásico</option>

<option>Corte Premium</option>

<option>Barba</option>

<option>Corte + Barba</option>

</select>

<h3>Método de Pago</h3>

<label for="pago">Seleccione un método de pago:</label>

<select id="pago" required>
    <option value="">Seleccione una opción</option>
    <option value="efectivo">💵 Efectivo</option>
    <option value="transferencia">🏦 Transferencia Bancaria</option>
    <option value="tarjeta">💳 Tarjeta de Crédito o Débito</option>
</select>

<div id="mensajePago" style="margin:15px 0; padding:15px; background:#f2f2f2; border-radius:8px;">
    Seleccione un método de pago para ver las instrucciones.
</div>

<button type="submit">Reservar</button>

</form>

</section>

<footer id="contacto">

<h3>Barbería Elegance</h3>

<p>📍 Av. Principal #123</p>

<p>📞 0999999999</p>

<p>✉ contacto@barberia.com</p>

<p>© 2026 Todos los derechos reservados.</p>

</footer>

<script>

document.getElementById("formulario").addEventListener("submit",function(e){

e.preventDefault();

alert("✅ Su cita ha sido reservada correctamente.");

this.reset();

});

</script>

</body>
</html>
